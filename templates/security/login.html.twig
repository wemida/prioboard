{% extends 'base.html.twig' %}

{% block title %}Login | PrioBoard{% endblock %}
{% block body_class %}admin-screen{% endblock %}

{% block body %}
    <main class="admin-page admin-login-page">
        <section class="panel login-panel">
            <div class="panel-heading">
                <p class="eyebrow">Private access</p>
                <h1>Login</h1>
            </div>

            {% if error %}
                <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form method="post" class="stack-form">
                <label>
                    <span>Username</span>
                    <input type="text" name="_username" value="{{ last_username }}" autocomplete="username" required autofocus>
                </label>
                <label>
                    <span>Password</span>
                    <input type="password" name="_password" autocomplete="current-password" required>
                </label>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button class="button button-primary" type="submit">Login</button>
            </form>

            <p class="muted">Default login on a fresh database: <strong>admin</strong> / <strong>admin</strong></p>
        </section>
    </main>
{% endblock %}
