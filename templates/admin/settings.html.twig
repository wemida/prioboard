{% extends 'base.html.twig' %}

{% block title %}PrioBoard | Settings{% endblock %}
{% block body_class %}admin-screen{% endblock %}

{% block body %}
    <main class="admin-page">
        <header class="admin-header">
            <div>
                <h1>Priority Board</h1>
            </div>
            <nav class="admin-nav">
                <a class="button" href="{{ path('app_board') }}">View board</a>
            </nav>
        </header>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <section class="settings-grid">
            <article class="panel">
                <div class="panel-heading">
                    <h2>Display settings</h2>
                    <p>Choose the public board look and feel.</p>
                </div>
                {{ form_start(settingsForm, { attr: { class: 'stack-form' } }) }}
                    {{ form_row(settingsForm.skin) }}
                    {{ form_row(settingsForm.fontSize) }}
                    {{ form_row(settingsForm.refreshInterval) }}
                    {{ form_row(settingsForm.deleteConfirmationEnabled) }}
                    <button class="button button-primary" type="submit">Save settings</button>
                {{ form_end(settingsForm) }}
            </article>

            <article class="panel">
                <div class="panel-heading">
                    <h2>Docs</h2>
                    <p>Priority Board is a simple, open-source Kanban like taskboard app to keep track of your work. <a href="https://github.com/changeme!">View the source code on GitHub</a>.</p>
                    <p>For E-Paper and monochrome Screens and you can change the skin to black and white appearance</p>
                </div>
            </article>

            <article class="panel">
                <div class="panel-heading">
                    <h2>Login settings</h2>
                    <p>Only one editor account exists for this board.</p>
                </div>
                {{ form_start(accountForm, { attr: { class: 'stack-form' } }) }}
                    {{ form_row(accountForm.username) }}
                    {{ form_row(accountForm.plainPassword) }}
                    <button class="button button-primary" type="submit">Save login</button>
                {{ form_end(accountForm) }}
            </article>

            <article class="panel">
                <div class="panel-heading">
                    <h2>API access</h2>
                    <p>The public API is readable anonymously. Writes require the API key in the <code>X-API-Key</code> header.</p>
                </div>
                <div class="stack-form">
                    <label>
                        <span>API key</span>
                        <div class="api-key-row">
                            <input type="text" value="{{ settings.apiKey }}" readonly disabled>
                            <form method="post" action="{{ path('app_admin_settings_api_key_regenerate') }}">
                                <button class="button button-primary" type="submit">Generate</button>
                            </form>
                        </div>
                    </label>
                </div>
                <br/><br/>
                <div class="api-example">
                    <p><strong>Read board:</strong> <code>GET {{ absolute_url(path('api_board')) }}</code></p>
                    <p><strong>Create card:</strong> <code>POST {{ absolute_url(path('api_card_create')) }}</code></p>
                    <p><strong>Move card:</strong> <code>POST {{ absolute_url(path('api_card_move', { id: 1, direction: 'up' }))|replace({'/1/': '/{id}/'}) }}</code></p>
                </div>
            </article>
        </section>
    </main>
{% endblock %}
