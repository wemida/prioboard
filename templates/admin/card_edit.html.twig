{% extends 'base.html.twig' %}

{% block title %}Edit Card | PrioBoard{% endblock %}
{% block body_class %}admin-screen{% endblock %}

{% block body %}
    <main class="admin-page">
        <header class="admin-header">
            <div>
                <h1>Edit card</h1>
            </div>
            <nav class="admin-nav">
                <a class="button" href="{{ path('app_admin') }}">Back to editor</a>
                <a class="button" href="{{ path('app_board') }}">View board</a>
            </nav>
        </header>

        <section class="panel edit-panel">
            {{ form_start(cardForm, { attr: { class: 'stack-form' } }) }}
                {{ form_row(cardForm.title) }}
                {{ form_row(cardForm.columnKey) }}
                {{ form_row(cardForm.color) }}
                <div class="button-row">
                    <button class="button button-primary" type="submit">Save</button>
                    <a class="button" href="{{ path('app_admin') }}">Cancel</a>
                </div>
            {{ form_end(cardForm) }}
        </section>
    </main>
{% endblock %}
