{% extends 'base.html.twig' %}

{% block title %}PrioBoard{% endblock %}
{% block body_class %}board-screen{% endblock %}
{% block body_attributes %}
    data-board-version="{{ settings.boardVersion }}"
    data-refresh-interval="{{ editable ? 0 : settings.refreshInterval }}"
    data-meta-url="{{ editable ? '' : path('api_board_meta') }}"
{% endblock %}

{% block body %}
    <main
        class="board-page board-page-{{ editable ? 'editable' : 'readonly' }}"
        data-board-app
        data-editable="{{ editable ? 'true' : 'false' }}"
        data-delete-confirmation="{{ settings.deleteConfirmationEnabled ? 'true' : 'false' }}"
        data-create-url="{{ path('app_board_manage_card_create') }}"
        data-card-update-template="{{ path('app_board_manage_card_update', { id: '__ID__' }) }}"
        data-card-delete-template="{{ path('app_board_manage_card_delete', { id: '__ID__' }) }}"
        data-card-move-template="{{ path('app_board_manage_card_move', { id: '__ID__' }) }}"
        data-controller="modal"
    >
        <header class="board-header">
            <div>
                <h1>Priority Board</h1>
            </div>
            <nav class="admin-nav">
                {% if editable %}
                    <a class="button" href="{{ path('app_admin_settings') }}">Settings</a>
                    <a class="button" href="{{ path('app_logout') }}">Logout</a>
                {% else %}
                    <a class="button" href="{{ path('app_login') }}" data-action="click->modal#open">Login</a>
                {% endif %}
            </nav>
        </header>

        <section class="board-shell">
            <div class="board-grid" data-board-columns>
                {% include 'board/_columns.html.twig' with {
                    columns: columns,
                    cardsByColumn: cardsByColumn,
                    editable: editable,
                    cardColors: cardColors
                } only %}
            </div>
        </section>

        {% if not editable %}
            <div class="modal-overlay {{ error ? '' : 'hidden' }}" data-modal-target="overlay" data-action="click->modal#close"></div>
            <div class="modal {{ error ? '' : 'hidden' }}" data-modal-target="modal">
                <section class="panel">
                    <div class="panel-heading">
                        <h1>Login</h1>
                    </div>

                    {% if error %}
                        <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    <form action="{{ path('app_login') }}" method="post" class="stack-form" data-turbo="false">
                        <label>
                            <span>Username</span>
                            <input type="text" name="_username" value="{{ last_username }}" autocomplete="username" required {{ error ? 'autofocus' : '' }}>
                        </label>
                        <label>
                            <span>Password</span>
                            <input type="password" name="_password" autocomplete="current-password" required>
                        </label>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button class="button button-primary" type="submit">Login</button>
                    </form>

                    <div class="modal-close-row">
                        <button class="button" data-action="click->modal#close">Cancel</button>
                    </div>
                </section>
            </div>
        {% endif %}
    </main>
{% endblock %}
